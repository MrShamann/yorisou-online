{
  "name": "yorisou-online",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "insights:ingest": "tsx scripts/insights-ingest.ts",
    "review:needs": "node --import tsx scripts/review-needs.ts",
    "validate:foundation": "tsx scripts/validate-foundation-repositories.ts",
    "test:agent-runtime": "node --conditions=react-server --import tsx lib/server/agent-runtime/__tests__/phase1.test.ts",
    "test:private-ai-providers": "node --import tsx lib/server/__tests__/privateAiProviderResolver.test.ts",
    "test:experience-cards": "node --conditions=react-server --import tsx lib/server/__tests__/experienceCards.test.ts",
    "test:recommendation-graph": "node --conditions=react-server --import tsx lib/server/__tests__/recommendationGraph.test.ts",
    "test:agent-runtime:db": "bash tests/agent-runtime/postgres-integration.sh",
    "test:c02": "node --import tsx lib/yorisou-tests/__tests__/c02.test.ts",
    "test:relationship-fatigue": "node --import tsx lib/yorisou-tests/__tests__/relationshipFatigue.test.ts",
    "yorisou:assets:check": "node scripts/yorisou/validate-persona-assets.mjs",
    "check:yorisou": "bash scripts/yorisou-check.sh",
    "check:env": "node scripts/yorisou-env-check.mjs",
    "smoke:companion": "node scripts/yorisou/companion-smoke.mjs",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed",
    "smoke:openclaw": "node scripts/openclaw-webhook-smoke.mjs",
    "smoke:hermes": "node scripts/hermes-webhook-smoke.mjs",
    "verify:automation": "npm run check:env && npm run smoke:openclaw && npm run smoke:hermes",
    "test:result-reveal": "node --import tsx lib/yorisou-tests/__tests__/resultReveal.test.ts",
    "test:imairo-snapshot": "node --import tsx lib/yorisou-tests/__tests__/imairoSnapshot.test.ts",
    "test:candidate-intake": "node --import tsx lib/yorisou-tests/__tests__/candidateIntake.test.ts",
    "test:state-field": "node --import tsx lib/yorisou-tests/__tests__/stateField.test.ts",
    "test:depth-field": "node --import tsx lib/yorisou-tests/__tests__/depthField.test.ts",
    "test:aix3": "node --import tsx lib/yorisou-tests/__tests__/aix3Completion.test.ts",
    "test:aix3b": "node --import tsx lib/yorisou-tests/__tests__/aix3bCompletion.test.ts",
    "test:aix3c": "node --import tsx lib/yorisou-tests/__tests__/aix3cCompletion.test.ts",
    "test:aix3d": "node --import tsx lib/yorisou-tests/__tests__/aix3dCompletion.test.ts",
    "test:aix3d2": "node --import tsx lib/yorisou-tests/__tests__/aix3d2Completion.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "gray-matter": "^4.0.3",
    "motion": "12.42.2",
    "next": "16.2.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "server-only": "^0.0.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  }
}
